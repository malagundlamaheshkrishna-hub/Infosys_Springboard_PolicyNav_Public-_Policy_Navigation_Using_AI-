                filtered_activities = [act for act in activities if act[0] == category]
            
            if not filtered_activities:
                st.markdown(f"""
                <div style="background:#111827;border:1px dashed #1e293b;border-radius:14px;
                            padding:30px;text-align:center;margin-top:10px;">
                    <div style="color:#475569;font-size:14px;">No {category} activity recorded.</div>
                </div>
