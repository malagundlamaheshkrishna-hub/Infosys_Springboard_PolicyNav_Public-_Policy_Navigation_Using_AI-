def check_password_strength(password: str):
    if not password: return "Empty", False
    score = 0
    if len(password) >= 8: score += 1
    if re.search(r"[A-Z]", password): score += 1
    if re.search(r"[a-z]", password): score += 1
    if re.search(r"[0-9]", password): score += 1
    if re.search(r"[@$!%*?&._-]", password): score += 1

    if score <= 2 or len(password) < 6: return "Weak (Use at least 8 chars, mixed case, numbers, special symbols)", False
    elif score == 3 or len(password) < 8: return "Medium (Could be stronger)", True
    else: return "Strong", True

