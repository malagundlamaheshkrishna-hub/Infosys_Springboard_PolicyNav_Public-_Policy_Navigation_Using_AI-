def translator_page(email):
    section_header("🌐", "Policy Translator", "Instantly translate policy text into regional languages")
    st.markdown("---")

    target_lang = st.selectbox("Response language:", ["English", "Hindi", "Tamil", "Kannada", "Telugu", "Marathi", "Bengali"])
    
    col1, col2 = st.columns(2)
    
    with col1:
        st.markdown("**Paste Text Here:**")
        source_text = st.text_area("Input Text", height=300, label_visibility="collapsed", placeholder="Enter text to translate...")
        
    with col2:
        st.markdown(f"**Output ({target_lang}):**")
        if source_text.strip():
            with st.spinner(f"Translating into {target_lang}..."):
                try:
                    # Default assumes input is English, but nllb-200 handles multiple sources
                    translated_text = nlp_engine.translate_fast(source_text, "English", target_lang)
                    st.text_area("Translated Text", value=translated_text, height=300, label_visibility="collapsed")
                except Exception as e:
                    st.error(f"Translation Error: {e}")
        else:
            st.text_area("Translated Text", value="", height=300, label_visibility="collapsed", placeholder="Translation will appear here...")

