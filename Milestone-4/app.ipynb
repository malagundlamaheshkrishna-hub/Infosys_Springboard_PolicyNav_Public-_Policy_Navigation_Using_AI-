import streamlit as st
import spacy, os
from pyvis.network import Network
from collections import Counter
import networkx as nx

@st.cache_resource(show_spinner=False)
def get_spacy_nlp():
    try:
        return spacy.load("en_core_web_sm")
    except:
        return None

APP_DIR = os.environ.get('APP_DIR', '.')

def generate_interactive_graph(docs, policy_name="all_policies"):
    nlp = get_spacy_nlp()
    if not docs or not nlp: return None

    G = nx.DiGraph()
    # Processing top docs (limit to prevent huge graphs)
    max_docs = min(len(docs), 150)

    color_map = {
        'ORG': '#3498db', 'LAW': '#f39c12',
        'GPE': '#e74c3c', 'PERSON': '#2ecc71', 'PRODUCT': '#9b59b6',
        'DATE': '#00bcd4', 'EVENT': '#ff9800', 'Entity': '#d2d7d3'
    }

    # Extract triples
    for i in range(max_docs):
        text = docs[i]['content'][:1000]
        doc = nlp(text)
        
        for sent in doc.sents:
            subj = None
            verb = None
            obj = None
            
            for token in sent:
                if "subj" in token.dep_ and not subj:
                    subj = token
                elif token.pos_ == "VERB" and not verb:
                    verb = token
                elif "obj" in token.dep_ and not obj:
                    obj = token
            
            if subj and verb and obj:
                s_text = subj.text.strip()
                v_text = verb.lemma_.upper().replace(" ", "_")
                o_text = obj.text.strip()
                
                # Basic filtering
                invalid_words = ['they', 'this', 'that', 'which', 'who', 'what', 'it', 'he', 'she', 'we', 'i', 'you']
                if len(s_text) > 2 and len(o_text) > 2 and s_text.lower() not in invalid_words and o_text.lower() not in invalid_words:
                    
                    s_group = 'Entity'
                    o_group = 'Entity'
                    
                    # Try to assign a named entity group if it matches
                    for ent in doc.ents:
                        if s_text in ent.text or ent.text in s_text:
                            s_group = ent.label_
                        if o_text in ent.text or ent.text in o_text:
                            o_group = ent.label_

                    # Add nodes
                    if s_text not in G: 
                        G.add_node(s_text, label=s_text.title(), group=s_group, color=color_map.get(s_group, color_map['Entity']))
                    if o_text not in G: 
                        G.add_node(o_text, label=o_text.title(), group=o_group, color=color_map.get(o_group, color_map['Entity']))
                        
                    # Add edge
                    if not G.has_edge(s_text, o_text):
                        G.add_edge(s_text, o_text, label=v_text, title=v_text)

    # Fallback to co-occurrence if graph is too sparse (less than 5 edges)
    if G.number_of_edges() < 5:
        G = nx.DiGraph()
        entity_counts = Counter()
        for i in range(max_docs):
            doc = nlp(docs[i]['content'][:1000])
            entities = [ent.text.strip() for ent in doc.ents if ent.label_ in color_map]
            entity_counts.update(entities)
            
        top_entities = {name for name, count in entity_counts.items() if count >= 2}
        
        for i in range(max_docs):
            doc = nlp(docs[i]['content'][:1000])
            current_entities = [ent for ent in doc.ents if ent.text.strip() in top_entities]
            
            for ent in current_entities:
                name = ent.text.strip()
                if name not in G:
                    G.add_node(name, label=name, group=ent.label_, color=color_map.get(ent.label_, color_map['Entity']))
                    
            for j in range(len(current_entities)):
                for k in range(j + 1, len(current_entities)):
                    src = current_entities[j].text.strip()
                    tgt = current_entities[k].text.strip()
                    if src != tgt and not G.has_edge(src, tgt) and not G.has_edge(tgt, src):
                        G.add_edge(src, tgt, label="ASSOCIATED_WITH", title="ASSOCIATED_WITH")

    # Limit to top connected components if graph is too large to speed up physics
    if G.number_of_nodes() > 100:
        components = sorted(nx.weakly_connected_components(G), key=len, reverse=True)
        keep_nodes = set()
        for c in components:
            if len(keep_nodes) >= 100: break
            keep_nodes.update(c)
        G = G.subgraph(keep_nodes).copy()

    # Create PyVis Network - White background, dark text
    net = Network(height="700px", width="100%", bgcolor="#ffffff", font_color="#111827", directed=True, notebook=False)

    for node_id, data in G.nodes(data=True):
        degree = G.degree(node_id)
        node_size = 20 + (degree * 3)
        net.add_node(
            node_id, 
            label=data.get('label', node_id), 
            size=node_size, 
            shape="dot",
            color=data.get('color'),
            title=f"Category: {data.get('group')}<br>Connections: {degree}",
            font={'size': 14, 'face': 'Inter', 'color': '#111827', 'strokeWidth': 2, 'strokeColor': '#ffffff'}
        )

    for src, tgt, data in G.edges(data=True):
        net.add_edge(
            src, tgt, 
            color="#9ca3af", 
            width=1.5, 
            label=data.get('label', ''),
            font={'size': 10, 'color': '#4b5563', 'align': 'middle'},
            arrows='to'
        )

    net.set_options("""
    {
      "interaction": {
        "hover": true,
        "hoverConnectedEdges": true,
        "selectConnectedEdges": true,
        "navigationButtons": true,
        "tooltipDelay": 150
      },
      "edges": {
        "color": { "inherit": false, "hover": "#ef4444", "highlight": "#ef4444" },
        "smooth": { "type": "continuous", "roundness": 0.5 }
      },
      "physics": {
        "forceAtlas2Based": {
            "gravitationalConstant": -100,
            "centralGravity": 0.01,
            "springLength": 200,
            "springConstant": 0.08
        },
        "solver": "forceAtlas2Based",
        "stabilization": { "enabled": true, "iterations": 150, "fit": true }
      }
    }
    """)

    os.makedirs(os.path.join(APP_DIR, "graphs"), exist_ok=True)
    safe_name = "".join([c if c.isalnum() else "_" for c in policy_name])
    output_path = os.path.join(APP_DIR, "graphs", f"policy_kg_{safe_name}.html")
    net.save_graph(output_path)

    with open(output_path, 'r', encoding='utf-8') as f:
        html_content = f.read()

    # Interactive JS
    custom_interaction_js = """
    network.on("stabilizationIterationsDone", function () {
        network.setOptions( { physics: false } );
    });

    network.on("hoverNode", function (params) {
        var connectedEdges = network.getConnectedEdges(params.node);
        network.body.data.edges.update(connectedEdges.map(id => ({id: id, color: "#ef4444", width: 3})));
    });
    network.on("blurNode", function (params) {
        var connectedEdges = network.getConnectedEdges(params.node);
        network.body.data.edges.update(connectedEdges.map(id => ({id: id, color: "#9ca3af", width: 1.5})));
    });

    network.on("doubleClick", function (params) {
        if (params.nodes.length > 0) {
            var selectedNode = params.nodes[0];
            var neighbors = network.getConnectedNodes(selectedNode);
            var allNodes = network.body.data.nodes.getIds();
            var toShow = neighbors.concat([selectedNode]);
            network.body.data.nodes.update(allNodes.map(id => ({
                id: id,
                hidden: !toShow.includes(id)
            })));
            network.fit();
        }
    });

    network.on("click", function (params) {
        if (params.nodes.length === 0) {
            var allNodes = network.body.data.nodes.getIds();
            network.body.data.nodes.update(allNodes.map(id => ({
                id: id,
                hidden: false
            })));
            network.fit();
        }
    });
    """

    html_content = html_content.replace('drawGraph();', f'drawGraph();\n{custom_interaction_js}')

    with open(output_path, 'w', encoding='utf-8') as f:
        f.write(html_content)

    return output_path

import streamlit as st
import time
import nlp_engine

def chat_page():
    st.markdown('<div class="neon-title" style="padding-top: 0px; font-size: 48px;">Infosys LLM Chat</div>', unsafe_allow_html=True)
    st.markdown('<div class="neon-sub">Secure AI Interface • Enterprise Grade</div>', unsafe_allow_html=True)

    if "messages" not in st.session_state:
        st.session_state.messages = []
    if "recent_searches" not in st.session_state:
        st.session_state.recent_searches = []

    # Optional sidebar history
    with st.sidebar:
        st.markdown("---")
        st.markdown("### 🕒 Recent Searches")
        if not st.session_state.recent_searches:
            st.info("No recent searches.")
        else:
            for i, search in enumerate(reversed(st.session_state.recent_searches[-5:])):
                st.markdown(f"<p style='font-size: 13px; color: #555555; background-color: #f1f3f5; padding: 5px; border-radius: 4px; margin-bottom: 5px; word-wrap: break-word;'>🔍 {search}</p>", unsafe_allow_html=True)

    # Display suggestions organically only when the chat is empty
    if len(st.session_state.messages) == 0:
        st.markdown("<br>", unsafe_allow_html=True)
        st.markdown("<h4 style='color: #a0a0ab; text-align: center; font-weight: 500;'>Try asking about...</h4>", unsafe_allow_html=True)
        
        col1, col2, col3 = st.columns(3)
        with col1:
            if st.button("🛡️ What are your active security policies?", use_container_width=True):
                suggest_prompt("What are your active security policies?")
        with col2:
            if st.button("⚙️ How does the Brute Force armor work?", use_container_width=True):
                suggest_prompt("How does the Brute Force armor work?")
        with col3:
            if st.button("📖 What does the Readability index measure?", use_container_width=True):
                suggest_prompt("What does the Readability index measure?")
        st.markdown("<br><br>", unsafe_allow_html=True)

    # Render Active Chat
    for msg in st.session_state.messages:
        with st.chat_message(msg["role"], avatar="⚡" if msg["role"] == "assistant" else "👤"):
            st.markdown(msg["content"])

    # Handle standard text injection
    if prompt := st.chat_input("Ask the LLM anything..."):
        send_message(prompt)

def suggest_prompt(text):
    st.session_state.messages.append({"role": "user", "content": text})
    send_message(text, bypass_append=True)

def send_message(prompt, bypass_append=False):
    if prompt not in st.session_state.recent_searches:
        st.session_state.recent_searches.append(prompt)
        
    if not bypass_append:
        st.session_state.messages.append({"role": "user", "content": prompt})
        with st.chat_message("user", avatar="👤"):
            st.markdown(prompt)

    with st.chat_message("assistant", avatar="⚡"):
        with st.spinner("Analyzing securely..."):
            # Simple NLP Simulation for the suggested questions
            p_lower = prompt.lower()
            if "security policies" in p_lower:
                response = "**Infosys Security Posture:**\n1. AES-encrypted SQLite databases\n2. Native bcrypt SHA-256 historical downgrade protection.\n3. Dynamic JWT tokens enforced at a 10-minute expiry threshold."
                st.markdown(response)
            elif "brute force" in p_lower:
                response = "**Brute Force Armor:**\nThe backend monitors authentication intervals via timestamp tracking. 3 consecutive failed attempts instantiates an immediate 60-second hardware-level UI blackout!"
                st.markdown(response)
            elif "readability" in p_lower:
                response = "**Readability NLP:**\nThe system dynamically loops text blocks mathematically extracting complex matrices including the Flesch-Kincaid index, determining exactly how many years of formal US education are required to understand your text."
                st.markdown(response)
            else:
                try:
                    response_stream = nlp_engine.stream_english_response(prompt)
                    response = st.write_stream(response_stream)
                except Exception as e:
                    response = f"LLM Generation Error: {e}"
                    st.markdown(response)
                
            st.session_state.messages.append({"role": "assistant", "content": response})
            
    if bypass_append:
        st.rerun()

