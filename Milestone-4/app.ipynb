import sqlite3
import bcrypt
import datetime
import time

DB_NAME = "users.db"
MAX_LOGIN_ATTEMPTS = 3
LOCKOUT_TIME = 60


def init_db():
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    # Users table
    c.execute('''CREATE TABLE IF NOT EXISTS users
                 (email TEXT PRIMARY KEY, 
                  password BLOB, 
                  username TEXT,
                  security_question TEXT,
                  security_answer TEXT,
                  created_at TEXT)''')
                  
    # Add new admin and locked columns if they don't exist
    try:
        c.execute("ALTER TABLE users ADD COLUMN is_admin INTEGER DEFAULT 0")
    except:
        pass
    try:
        c.execute("ALTER TABLE users ADD COLUMN is_locked INTEGER DEFAULT 0")
    except:
        pass
    try:
        c.execute("ALTER TABLE users ADD COLUMN profile_pic TEXT")
    except:
        pass

    # Readability feature usage logs
    c.execute('''CREATE TABLE IF NOT EXISTS readability_logs
                 (id INTEGER PRIMARY KEY AUTOINCREMENT,
                  email TEXT,
                  scan_time TEXT)''')

    # Password history
    c.execute('''CREATE TABLE IF NOT EXISTS password_history
                 (id INTEGER PRIMARY KEY AUTOINCREMENT,
                  email TEXT,
                  password BLOB,
                  set_at TEXT)''')

    # Login attempts
    c.execute('''CREATE TABLE IF NOT EXISTS login_attempts
                 (email TEXT PRIMARY KEY,
                  attempts INTEGER,
                  last_attempt REAL)''')

    # Activity history
    c.execute('''CREATE TABLE IF NOT EXISTS activity_history
                 (id INTEGER PRIMARY KEY AUTOINCREMENT,
                  email TEXT,
                  activity_type TEXT,
                  input_text TEXT,
                  output_text TEXT,
                  timestamp TEXT)''')

    # Feedback
    c.execute('''CREATE TABLE IF NOT EXISTS feedback
                 (id INTEGER PRIMARY KEY AUTOINCREMENT,
                  email TEXT,
                  section TEXT,
                  rating INTEGER,
                  comments TEXT,
                  timestamp TEXT)''')

    conn.commit()
    conn.close()

def _get_timestamp():
    return datetime.datetime.utcnow().strftime("%Y-%m-%d %H:%M:%S")

def register_user(email, password, username, security_question, security_answer):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    try:
        salt = bcrypt.gensalt()
        hashed = bcrypt.hashpw(password.encode('utf-8'), salt)
        now = _get_timestamp()
        c.execute("""INSERT INTO users (email, password, username, security_question, security_answer, created_at) 
                     VALUES (?, ?, ?, ?, ?, ?)""", 
                  (email, hashed, username, security_question, security_answer, now))
        c.execute("INSERT INTO password_history (email, password, set_at) VALUES (?, ?, ?)", (email, hashed, now))
        conn.commit()
        return True
    except sqlite3.IntegrityError:
        return False
    finally:
        conn.close()

def authenticate_user(email, password):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute("SELECT password, username, is_admin, is_locked FROM users WHERE email = ?", (email,))
    data = c.fetchone()
    conn.close()
    if data:
        stored_hash, username, is_admin, is_locked = data
        if is_locked == 1:
            return False, None, False, "ACCOUNT_DISABLED"
            
        if bcrypt.checkpw(password.encode('utf-8'), stored_hash):
            reset_attempts(email)
            log_activity(email, "Login", "User Authenticated", "SUCCESS")
            return True, username, bool(is_admin), "SUCCESS"
            
    increment_attempt(email)
    return False, None, False, "AUTH_FAILED"

