def set_user_lock(email, status=1):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute("UPDATE users SET is_locked = ? WHERE email = ?", (status, email))
    conn.commit()
    conn.close()


# --- Rate Limiting ---
def get_attempts(email):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute("SELECT attempts, last_attempt FROM login_attempts WHERE email = ?", (email,))
    data = c.fetchone()
    conn.close()
    return data if data else (0, 0)

def increment_attempt(email):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    attempts, _ = get_attempts(email)
    c.execute("INSERT OR REPLACE INTO login_attempts VALUES (?, ?, ?)",
              (email, attempts + 1, time.time()))
    conn.commit()
    conn.close()

def reset_attempts(email):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute("DELETE FROM login_attempts WHERE email = ?", (email,))
    conn.commit()
    conn.close()

def is_rate_limited(email):
    attempts, last_attempt = get_attempts(email)
    if attempts >= MAX_LOGIN_ATTEMPTS:
        remaining = float(LOCKOUT_TIME) - (time.time() - float(last_attempt))
        if remaining > 0:
            return True, int(remaining)
        else:
            reset_attempts(email)
    return False, 0

def get_admin_stats():
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute("SELECT COUNT(*) FROM users")
    total_users = c.fetchone()[0]
    
    c.execute("SELECT COUNT(*) FROM readability_logs")
    total_scans = c.fetchone()[0]
    
    now = time.time()
    c.execute("SELECT COUNT(*) FROM login_attempts WHERE attempts >= ? AND ? - last_attempt <= ?", 
              (MAX_LOGIN_ATTEMPTS, now, LOCKOUT_TIME))
    locked_accounts = c.fetchone()[0]
    
    c.execute("SELECT COUNT(*) FROM password_history")
    pass_history_count = c.fetchone()[0]
    password_changes = pass_history_count - total_users if pass_history_count > total_users else 0
    
    conn.close()
    
    return {
        "total_users": total_users,
        "password_changes": password_changes,
        "locked_accounts": locked_accounts,
        "total_scans": total_scans
    }

def log_readability_scan(email):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute("INSERT INTO readability_logs (email, scan_time) VALUES (?, ?)", (email, _get_timestamp()))
    conn.commit()
    conn.close()

def get_readability_activity():
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute("""
        SELECT email, COUNT(*) as scan_count, MAX(scan_time) as last_scan
        FROM readability_logs 
        GROUP BY email 
        ORDER BY last_scan DESC
    """)
    activity = c.fetchall()
    conn.close()
    return activity

def clear_all_lockouts():
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute("DELETE FROM login_attempts")
    conn.commit()
    conn.close()

def get_all_users():
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute("SELECT email, username, created_at, is_admin, is_locked FROM users ORDER BY created_at DESC")
    users = c.fetchall()
    conn.close()
    return users

def delete_user(email):
    conn = sqlite3.connect(DB_NAME)
