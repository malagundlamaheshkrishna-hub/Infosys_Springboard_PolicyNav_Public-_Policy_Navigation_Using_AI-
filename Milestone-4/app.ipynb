def signup_page():
    st.markdown('<div class="neon-title">Registration</div>', unsafe_allow_html=True)
    _, mid, _ = st.columns([1, 0.8, 1])
    with mid:
        if st.session_state.get('signup_step', 1) == 1:
            name = st.text_input("Full Name")
            email = st.text_input("Email")
            p1 = st.text_input("Create Password", type="password")
            p2 = st.text_input("Confirm Password", type="password")
            s_quest = st.selectbox("Security Question", ["Name of first pet?", "Mother's maiden name?", "City of birth?"])
            s_ans = st.text_input("Answer")
            
            if st.button("Generate OTP", use_container_width=True):
                if name and email and p1 and p2 and s_ans and p1 == p2:
                    if db.check_user_exists(email):
                        st.markdown("<p class='error-text'>User already exists. Please use a different email or log in.</p>", unsafe_allow_html=True)
                    else:
                        otp = str(random.randint(100000, 999999))
                        success, msg = send_otp_email(email, otp)
                        if success:
                            st.session_state['signup_otp'] = otp
                            st.session_state['signup_otp_time'] = time.time()
                            st.session_state['temp_user_data'] = {
                                'email': email, 'password': p1, 'username': name, 
                                'security_question': s_quest, 'security_answer': s_ans.lower().strip()
                            }
                            st.session_state['signup_step'] = 2
                            st.rerun()
                        else:
                            st.error(msg)
                else:
                    missing = []
                    if not name: missing.append("Full Name")
                    if not email: missing.append("Email")
                    if not p1: missing.append("Password")
                    if not p2: missing.append("Confirm Password")
                    if not s_ans: missing.append("Security Question Answer")
                    
                    if missing:
                        st.markdown(f"<p class='error-text'>Please provide the following: {', '.join(missing)}</p>", unsafe_allow_html=True)
                    elif p1 != p2:
                        st.markdown("<p class='error-text'>Passwords do not match.</p>", unsafe_allow_html=True)
        else:
            st.info(f"OTP sent to {st.session_state['temp_user_data']['email']}")
            otp_in = st.text_input("6-Digit OTP")
            if st.button("Verify & Create", use_container_width=True):
                if not otp_in:
                    st.markdown("<p class='error-text'>Please enter the 6-Digit OTP.</p>", unsafe_allow_html=True)
                elif time.time() - st.session_state.get('signup_otp_time', 0) > 600:
                    st.error("OTP has expired. Please generate a new one.")
                elif st.session_state.get('signup_otp') == otp_in:
                    t = st.session_state['temp_user_data']
                    if db.register_user(t['email'], t['password'], t['username'], t['security_question'], t['security_answer']):
                        st.success("Account Secured!")
                        time.sleep(1)
                        st.session_state['page'] = 'login'
                        st.session_state['signup_step'] = 1
                        st.rerun()
                else:
                    st.error("Wrong OTP or Verification Failed.")
                    
        if st.button("Back", use_container_width=True): 
            st.session_state['page'] = 'login'
            st.session_state['signup_step'] = 1
            st.rerun()
