            </div>
        </div>
        """, unsafe_allow_html=True)
        return

    # Define constraint categories
    categories = ["All", "RAG Search", "Summarization", "Readability", "Knowledge Graph"]
    tabs = st.tabs(categories)
    
    type_colors = {
        "RAG Search":     "#6366f1",
        "Summarization":  "#0ea5e9",
        "Readability":    "#10b981",
        "Knowledge Graph":"#f59e0b",
