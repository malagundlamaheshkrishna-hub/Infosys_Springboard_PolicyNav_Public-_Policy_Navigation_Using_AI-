    return None

def get_user_data(email):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute("SELECT username, security_question, security_answer, profile_pic FROM users WHERE email = ?", (email,))
    data = c.fetchone()
    conn.close()
    if data:
        return {
            'username': data[0],
            'security_question': data[1],
            'security_answer': data[2],
