import streamlit as st
import PyPDF2
import readability
from utils import create_gauge

@st.cache_data(show_spinner="Analyzing readability metrics (Complex textstat algorithms)...")
def get_readability_metrics(text):
    analyzer = readability.ReadabilityAnalyzer(text)
    return analyzer, analyzer.get_all_metrics()

def readability_page():
    import db
    user_data = st.session_state.get('user_data')
    
    st.title("Readability Analyzer")
    txt = st.text_area("Input Text (min 50 chars)")
    up = st.file_uploader("Or Upload PDF/TXT", type=["pdf", "txt"])
    @st.cache_data(show_spinner="Extracting PDF Text...")
    def extract_pdf_text(file_bytes):
        reader = PyPDF2.PdfReader(file_bytes)
        return "".join([p.extract_text() for p in reader.pages])

    if up:
        if up.type == "application/pdf":
            extracted = extract_pdf_text(up)
            if not extracted or not extracted.strip():
                st.error("Text Extraction Failed. This appears to be a scanned image-based PDF. PyPDF2 only works with text-based PDFs.")
                txt = ""
            else:
                txt = extracted
        else: txt = up.getvalue().decode()

    if st.button("Analyze", type="primary"):
        if not txt: st.error("Please insert text or upload a valid text-based file.")
        elif len(txt) < 50: st.error("Text must be ≥ 50 characters. Short text gives inaccurate readability metrics.")
        elif len(txt) > 20000: st.error("Text length strictly exceeds 20,000 character safe-limit. To protect server compute, please chunk the document.")
        else:
            if user_data:
                db.log_readability_scan(user_data['sub'])
            analyzer, score = get_readability_metrics(txt)
            st.markdown("---")
            
            # --- Expanders for indices ---
            e1, e2, e3 = st.columns(3)
            with e1:
                with st.expander("About Flesch Ease"): st.write("Measures readability based on sentence length and word length. Higher is easier.")
                st.plotly_chart(create_gauge(score["Flesch Reading Ease"], "Flesch Ease", 0, 100, "#ffcf20"), use_container_width=True)
            with e2:
                with st.expander("About Kincaid Grade"): st.write("Presents the score as a U.S. grade level. Lower means easier to read.")
                st.plotly_chart(create_gauge(score["Flesch-Kincaid Grade"], "Kincaid Grade", 0, 20, "#ff6b6b"), use_container_width=True)
            with e3:
                with st.expander("About SMOG"): st.write("Estimates the years of education needed to understand a piece of writing.")
                st.plotly_chart(create_gauge(score["SMOG Index"], "SMOG Index", 0, 20, "#4caf50"), use_container_width=True)
                
            e4, e5 = st.columns(2)
            with e4:
                with st.expander("About Gunning Fog"): st.write("Estimates the years of formal education needed to understand the text on a first reading.")
                st.plotly_chart(create_gauge(score["Gunning Fog"], "Gunning Fog", 0, 20, "#0078d4"), use_container_width=True)
            with e5:
                with st.expander("About Coleman-Liau"): st.write("Relies on characters instead of syllables per word to estimate grade level.")
                st.plotly_chart(create_gauge(score["Coleman-Liau"], "Coleman-Liau", 0, 20, "#00cc66"), use_container_width=True)

            # --- Text Statistics ---
            st.markdown("<h3 style='text-align: center;'>Text Statistics</h3>", unsafe_allow_html=True)
            st.markdown("<br>", unsafe_allow_html=True)
            st1, st2, st3, st4, st5 = st.columns(5)
            st1.metric("Sentences", analyzer.num_sentences)
            st2.metric("Words", analyzer.num_words)
            st3.metric("Syllables", analyzer.num_syllables)
            st4.metric("Complex Words", analyzer.complex_words)
            st5.metric("Characters", analyzer.char_count)

